            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tickets"
              ]
            }
          }
        },
        {
          "name": "Get Ticket Details",
          "request": {
