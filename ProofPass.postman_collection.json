                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/deactivate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "events",
                "{{event_id}}",
                "deactivate"
              ]
            }
          }
        }
      ]
    },
