            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/entry/{{ticket_id}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
