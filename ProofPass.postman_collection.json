{
  "info": {
    "name": "ProofPass API",
    "description": "Decentralized Ticket Management System - Base Sepolia Testnet",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "phone",
      "value": "+919876543210"
    },
    {
      "key": "event_id",
      "value": "0"
    },
    {
      "key": "ticket_id",
      "value": "0"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"john_doe\", \"password\": \"$2b$10$u7sH8m9n5\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/admin-login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "admin-login"
              ]
            }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/send-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "send-otp"
              ]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\", \"otp\": \"000000\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-otp"
              ]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Get Admin Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/admin-me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "admin-me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List All Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "events"
              ]
            }
          }
        },
        {
          "name": "Get Event Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
