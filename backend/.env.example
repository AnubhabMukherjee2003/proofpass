# Blockchain Configuration
RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
CHAIN_ID=31337

# Private key for signing transactions (keep secure in production!)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# JWT & Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_JWT_SECRET=admin-secret-key-change-in-production

# Hash Salt (fixed per deployment, used for OTP generation and phone hashing)
SALT=proofpass-salt-v1

# Twilio SMS (optional - OTP will be logged to console if not configured)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# Pinata IPFS (optional - event images won't be uploaded if not configured)
PINATA_API_KEY=your-pinata-api-key
PINATA_API_SECRET=your-pinata-secret-key

# Environment
NODE_ENV=development

# Server Port
PORT=3000
