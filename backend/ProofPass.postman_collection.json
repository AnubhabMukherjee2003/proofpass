{
  "info": {
    "name": "ProofPass API Collection",
    "description": "Complete API collection for ProofPass ticketing system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "phone",
      "value": "+919876543210"
    },
    {
      "key": "admin_phone",
      "value": "+919876543210"
    },
    {
      "key": "otp",
      "value": ""
    },
    {
      "key": "payment_id",
      "value": ""
    },
    {
      "key": "ticket_id",
      "value": ""
    },
    {
      "key": "event_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('admin_token', jsonData.token);",
                  "    console.log('Admin token saved: ' + jsonData.admin.username);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"john_doe\", \"password\": \"$2b$10$u7sH8m9n5\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/admin-login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "admin-login"]
            }
          }
        },
        {
          "name": "Get Admin Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/admin-me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "admin-me"]
            }
          }
        },
        {
          "name": "Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('OTP sent successfully to phone');",
                  "    // Check backend console for OTP in development mode",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/send-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.token);",
                  "    console.log('JWT Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\", \"otp\": \"000000\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List All Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var events = pm.response.json();",
                  "    if (events.length > 0) {",
                  "        pm.environment.set('event_id', events[0].eventId);",
                  "        console.log('First event ID saved');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/events",
              "host": ["{{base_url}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Get Event Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}"]
            }
          }
        },
        {
          "name": "Create Event (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "DevFest 2025",
                  "type": "text"
                },
                {
                  "key": "location",
                  "value": "Kolkata",
                  "type": "text"
                },
                {
                  "key": "date",
                  "value": "1754000000",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "1000000000000000",
                  "type": "text"
                },
                {
                  "key": "capacity",
                  "value": "500",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/events",
              "host": ["{{base_url}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Deactivate Event (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/deactivate",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "deactivate"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments & Tickets",
      "item": [
        {
          "name": "Create Fake Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('payment_id', jsonData.paymentId);",
                  "    console.log('Payment ID saved: ' + jsonData.paymentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/payments/fake",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "fake"]
            }
          }
        },
        {
          "name": "Book Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('Ticket booked successfully');",
                  "    // Note: ticketId would be retrieved from contract logs",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"eventId\": \"{{event_id}}\", \"paymentId\": \"{{payment_id}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": ["{{base_url}}"],
              "path": ["api", "tickets"]
            }
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tickets",
              "host": ["{{base_url}}"],
              "path": ["api", "tickets"]
            }
          }
        },
        {
          "name": "Get Ticket Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tickets/{{ticket_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tickets", "{{ticket_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Entry Gate (Admin)",
      "item": [
        {
          "name": "Confirm Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"{{phone}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/entry/{{ticket_id}}/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "entry", "{{ticket_id}}", "confirm"]
            }
          }
        },
        {
          "name": "Check Ticket Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/entry/{{ticket_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "entry", "{{ticket_id}}", "status"]
            }
          }
        },
        {
          "name": "Get Event Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/entry/stats/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "entry", "stats", "{{event_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    }
  ]
}
